{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fridge Inventory",
  "description": "Food and drink inventory for the household",
  "type": "object",
  "required": [
    "schema_version",
    "items",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "name",
          "added_at"
        ],
        "properties": {
          "item_id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "meal",
              "ingredient",
              "snack",
              "drink",
              "dairy",
              "fruit",
              "vegetable",
              "meat",
              "seafood",
              "grain",
              "frozen",
              "sauce",
              "other"
            ]
          },
          "quantity": {
            "type": [
              "number",
              "string"
            ]
          },
          "location": {
            "type": "string",
            "enum": [
              "fridge",
              "freezer",
              "pantry",
              "shelf",
              "counter",
              "transit"
            ]
          },
          "added_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "consumed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "consumed_quantity": {
            "type": [
              "number",
              "string",
              "null"
            ]
          },
          "notes": {
            "type": "string"
          },
          "added_by": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "ordered_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "expected_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
