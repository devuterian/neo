{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neo.local/schemas/medical.schema.json",
  "title": "Neo medical records",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "records", "updated_at"],
  "properties": {
    "schema_version": {"const": 1},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["medical_id", "provider", "title", "last_date", "cycle_days", "kind", "note", "updated_at"],
        "properties": {
          "medical_id": {"type": "string", "format": "uuid"},
          "provider": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "last_date": {"type": "string", "format": "date"},
          "cycle_days": {"type": ["integer", "null"], "minimum": 1},
          "kind": {"type": ["string", "null"]},
          "note": {"type": ["string", "null"]},
          "updated_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
